# Required GitHub Actions secrets for the release pipeline.
# Values use 1Password secret references (op:// URIs).
#
# Usage:
#   cp .env.example .env          # copy and fill in your vault paths
#   op run --env-file .env -- make secrets
#
# Or inline:
#   op run --env-file .env.example -- make secrets

# GitHub PAT with `repo` scope on yowainwright/homebrew-tap
# Needed by release.yml to push Formula/pre.rb after each release
HOMEBREW_TAP_TOKEN=op://Private/homebrew-tap-pat/token

# Codecov upload token (optional — test coverage uploads)
CODECOV_TOKEN=op://Private/codecov-pre/token
